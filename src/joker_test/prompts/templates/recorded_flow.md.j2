```python
"""录制流程转测试（基于语义化定位）。"""
from __future__ import annotations

from joker_test.executor.base import ExecutorBackend


def test_navigate_and_return(backend: ExecutorBackend) -> None:
    """点击目标按钮应进入新界面，验证后返回。"""
    # 1. 等起始界面就绪
    backend.wait_until(
        lambda: any("进入" in t for t in backend.state.texts),
        timeout=15.0,
    )

    # 2. 点击按钮（用录制的语义化定位）
    clicked = backend.click_text("进入地牢")
    assert clicked, "未找到'进入地牢'按钮"

    # 3. wait_until 等新界面出现
    backend.wait_until(
        lambda: any("英雄" in t for t in backend.state.texts),
        timeout=10.0,
    )
    texts = backend.state.texts
    assert any("英雄" in t for t in texts), f"未进入预期界面，实际: {texts}"

    # 4. 返回原界面
    backend.press_key("escape")
    backend.wait_until(
        lambda: any("进入" in t for t in backend.state.texts),
        timeout=10.0,
    )
```
